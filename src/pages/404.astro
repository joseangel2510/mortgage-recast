---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found | RecastWise"
  description="That page doesn't exist — but your new mortgage payment is one calculation away."
  path="/404/"
>
  <div class="wrap" style="padding-block: 4rem; text-align: center;">
    <h1>404 — not on the schedule</h1>
    <p style="margin: 1rem auto 2rem; color: var(--ink-2);">This page doesn't exist. Your recast numbers, though, are one click away.</p>
    <a class="btn btn-primary" href="/">Open the recast calculator →</a>
  </div>
</Base>
